<!-- Header Component -->
<header class="header">
  <div class="container">
    <nav class="navbar">
      <!-- Logo (wordmark testuale, stile neo-brutalista) -->
      <a href="{{ '/' | url }}" class="logo logo-sospatto" aria-label="SOS Patto — Home">
        <svg class="logo-buoy" viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
          <circle cx="12" cy="12" r="10" fill="#33B1FF" stroke="#1A1A1A" stroke-width="2"/>
          <circle cx="12" cy="12" r="4.5" fill="#FFFFFF" stroke="#1A1A1A" stroke-width="2"/>
          <line x1="12" y1="2" x2="12" y2="7.5" stroke="#FFFFFF" stroke-width="2.5"/>
          <line x1="12" y1="16.5" x2="12" y2="22" stroke="#FFFFFF" stroke-width="2.5"/>
          <line x1="2" y1="12" x2="7.5" y2="12" stroke="#FFFFFF" stroke-width="2.5"/>
          <line x1="16.5" y1="12" x2="22" y2="12" stroke="#FFFFFF" stroke-width="2.5"/>
        </svg>
        <span class="sp-logo-sos">S.O.S.</span><span class="sp-logo-word">Patto</span>
      </a>

      <!-- Mobile Menu Toggle -->
      <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
        ☰
      </button>

      <!-- Navigation Menu -->
      {% include "components/nav.liquid" %}
    </nav>
  </div>
</header>
